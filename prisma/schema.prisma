// Prisma Schema for Neon Protocol MVP
// Simplified Version - 2026-04-01

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

// ================== 枚举类型 ==================

enum OrderStatus {
  PENDING
  CONFIRMED
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum PaymentMethod {
  USDC
  ETH
  CREDIT_CARD
}

enum MilestoneStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

// ================== 核心模型 ==================

model Organization {
  id          String   @id @default(uuid())
  name        String
  email       String   @unique
  industry    String?
  description String?
  website     String?
  type        String      @default("DEMANDER")
  verified    Boolean   @default(false)
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  users       User[]
  tasks       Task[]
  orders      Order[]
}

model User {
  id          String   @id @default(uuid())
  orgId       String
  name        String
  email       String   @unique
  password    String
  role        String      @default("EXPERT")
  avatar      String?
  bio         String?
  walletAddress String?
  trustScore  Float     @default(0)
  verified    Boolean   @default(false)
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  organization    Organization  @relation(fields: [orgId], references: [id])
  agentProfile AgentProfile?
  agentOrders  Order[]  @relation("AgentOrders")
}

model AgentProfile {
  id              String   @id @default(uuid())
  userId          String  @unique
  title           String
  bio             String?
  skills          Json
  experienceYears Float?
  completedTasks   Int     @default(0)
  rating          Float   @default(0)
  priceRange      String?
  availability    String?
  verified        Boolean @default(false)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  user            User   @relation(fields: [userId], references: [id])
}

// ================== 任务系统 ==================

model Task {
  id              String   @id @default(uuid())
  orgId           String
  title           String
  description     String
  category        String
  tags            Json
  budget          Float?
  deadline        DateTime?
  status          String   @default("OPEN") // OPEN, MATCHED, IN_PROGRESS, COMPLETED, CANCELLED
  attachments     Json?
  requirements    Json?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  organization    Organization @relation(fields: [orgId], references: [id])
  orders          Order[]
}

// ================== 订单系统 ==================

model Order {
  id              String        @id @default(uuid())
  taskId          String
  agentId         String
  organizationId  String
  status          OrderStatus   @default(PENDING)
  totalAmount     Float
  message         String?
  paymentMethod   PaymentMethod @default(USDC)
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  task            Task        @relation(fields: [taskId], references: [id])
  agent           User        @relation("AgentOrders", fields: [agentId], references: [id])
  organization    Organization @relation(fields: [organizationId], references: [id])
  milestones      Milestone[]
}

model Milestone {
  id              String          @id @default(uuid())
  orderId         String
  title           String
  description     String
  amount          Float
  dueDate         DateTime?
  status          MilestoneStatus @default(PENDING)
  order           Int             @default(0)
  completedAt     DateTime?
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  order_record    Order   @relation(fields: [orderId], references: [id])
}
