// Prisma Schema for Neon Protocol MVP
// Generated on 2026-04-01

generator client {
  provider = "sqlite"
  previewFeatures = ["preview"]
  output   = "../prisma/prisma-client"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL", "file:./dev.db")
}

// ================== 核心模型 ==================

/// Organization 模型（组织/企业）
model Organization {
  id          String   @id @default(uuid()) @db.Uuid
  name        String
  email      String  @unique
  industry    String?
  description String?
  website     String?
  logo       String?
  type        OrganizationType @default(DEMANDER)
  verified    Boolean     @default(false)
  trustScore Float         @default(0)
  createdAt  DateTime    @default(now())
  updatedAt  DateTime        @updatedAt
}

enum OrganizationType {
  DEMANDER      // 鲨鱼需求方
  EXPERT         // 专家方
}

/// User 模型（用户 - 包括需求方和专家两种角色）
model User {
  id          String   @id @default(uuid()) @db.Uuid
  orgId       String
  name        String
  email       String  @unique
  password    String?
  role        UserRole      @default(EXPERT)
  avatar      String?
  bio         String?
  skills      String[]    // 专家技能标签
  walletAddress String?    // 专家钱包地址
  trustScore  Float         @default(0)
  verified    Boolean     @default(false)
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt
}

enum UserRole {
  DEMANDER      // 鲨鱼需求方（企业人员）
  EXPERT         // 专家
  ADMIN          // 管理员
}

/// Task 模型（需求方发布的任务）
model Task {
  id          String   @id @default(uuid()) @db.Uuid
  orgId       String
  title       String
  description String
  industry    String?
  region      String?
  budget      Float?
  deadline    DateTime?
  template    String?    // 交付模板（如：PDF报告、咨询）
  status      TaskStatus    @default(PENDING)
  matchedAgents Json[]    @relation(fields: [id], references: Agent)
  createdAt  DateTime    @default(now())
  updatedAt  DateTime        @updatedAt
}

enum TaskStatus {
  PENDING       // 待匹配
  MATCHED       // 已匹配专家
  ACCEPTED      // 专家已接单
  IN_PROGRESS   // 进行中
  SUBMITTED     // 已提交交付
  REVIEWED       // 平台审核中
  COMPLETED     // 已完成
  CANCELLED     // 已取消
}

/// Order模型（交易订单）
model Order {
  id          String   @id @default(uuid()) @db.Uuid
  taskId      String
  agentId     String?
  status      OrderStatus   @default(PENDING)
  budget      Float
  escrowAmount Float?      // 托管金额
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt
  completedAt DateTime?

  task       Task     @relation(fields: [id], references: Task)
  agent      Agent?    @relation(fields: [id], references: Agent)

  @@index([taskId])
  @@index([agentId])
}

enum OrderStatus {
  PENDING       // 待确认
  CONFIRMED     // 已确认
  IN_PROGRESS   // 进行中
  COMPLETED     // 已完成
  CANCELLED     // 已取消
  REFUNDED       // 已退款
}

/// AgentProfile 模型（专家档案 - 公开信息）
model AgentProfile {
  id          String   @id @default(uuid()) @db.Uuid
  userId      String  @unique
  title       String
  bio         String?
  skills      String[]
  experienceYears Float?
  completedTasks Int            @default(0)
  rating      Float         @default(0)
  priceRange  String?
  availability String?
  verified    Boolean     @default(false)
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt

  user User  @relation(fields: [id], references: User)
}
